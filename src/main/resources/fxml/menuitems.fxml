<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.halimawburgersystem.MenuItemsController"
      stylesheets="@../css/common.css, @../css/login.css, @../css/dashboard.css, @../css/menuitems.css">

    <VBox styleClass="sidebar" prefWidth="240" spacing="4">
        <padding><Insets top="16" right="8" bottom="16" left="8"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-logo-section">
            <StackPane styleClass="sidebar-logo-icon" prefWidth="32" prefHeight="32">
                <SVGPath content="M6 5C6 3.89543 6.89543 3 8 3C9.10457 3 10 3.89543 10 5C10 6.10457 9.10457 7 8 7C6.89543 7 6 6.10457 6 5ZM5.49998 8L10.5 8C11.3284 8 12 8.67157 12 9.5C12 10.6161 11.541 11.5103 10.7879 12.1148C10.0466 12.7098 9.05308 13 8 13C6.94692 13 5.95342 12.7098 5.21215 12.1148C4.45897 11.5103 4 10.6161 4 9.5C4 8.67161 4.67156 8 5.49998 8ZM8 0C3.58172 0 0 3.58172 0 8C0 12.4183 3.58172 16 8 16C12.4183 16 16 12.4183 16 8C16 3.58172 12.4183 0 8 0ZM1 8C1 4.13401 4.13401 1 8 1C11.866 1 15 4.13401 15 8C15 11.866 11.866 15 8 15C4.13401 15 1 11.866 1 8Z" styleClass="logo-svg"/>
            </StackPane>
            <Label styleClass="sidebar-logo-text" text="BurgerHQ"/>
        </HBox>

        <Label styleClass="sidebar-section-label" text="MAIN">
            <padding><Insets top="16" left="8"/></padding>
        </Label>

        <Button fx:id="btnDashboard" styleClass="nav-item" text="Dashboard" onAction="#onNavigateDashboard">
            <graphic>
                <SVGPath content="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Button fx:id="btnOrders" styleClass="nav-item" text="Orders" onAction="#onNavigateOrders">
            <graphic>
                <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Button fx:id="btnKitchen" styleClass="nav-item" text="Kitchen Queue" onAction="#onNavigateKitchen">
            <graphic>
                <SVGPath content="M18 3v2h-2V3H8v2H6V3H4v18h2v-2h2v2h8v-2h2v2h2V3h-2zM8 17H6v-2h2v2zm0-4H6v-2h2v2zm0-4H6V7h2v2zm10 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V7h2v2z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Label styleClass="sidebar-section-label" text="MENU">
            <padding><Insets top="16" left="8"/></padding>
        </Label>

        <Button fx:id="btnMenuItems" styleClass="nav-item" text="Menu Items" onAction="#onNavigateMenuItems">
            <graphic>
                <SVGPath content="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Button fx:id="btnCombos" styleClass="nav-item" text="Combos &amp; Promos" onAction="#onNavigateCombos">
            <graphic>
                <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Button fx:id="btnInventory" styleClass="nav-item" text="Inventory" onAction="#onNavigateInventory">
            <graphic>
                <SVGPath content="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.06 15.94 0 13.36 0c-1.46 0-2.68.75-3.48 1.88L12 4l2.12-2.12C14.5 1.32 14.9 1 15.5 1c.83 0 1.5.67 1.5 1.5S16.33 4 15.5 4H4C2.9 4 2 4.9 2 6v14c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-7.5 11.5h-3v-3h-3v-3h3v-3h3v3h3v3h-3v3z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Label styleClass="sidebar-section-label" text="BUSINESS">
            <padding><Insets top="16" left="8"/></padding>
        </Label>

        <Button fx:id="btnSales" styleClass="nav-item" text="Sales Reports" onAction="#onNavigateSales">
            <graphic>
                <SVGPath content="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Button fx:id="btnStaff" styleClass="nav-item" text="Staff" onAction="#onNavigateStaff">
            <graphic>
                <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z" styleClass="nav-svg"/>
            </graphic>
            <padding><Insets top="8" right="8" bottom="8" left="24"/></padding>
        </Button>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-footer">
            <padding><Insets top="12" right="8" bottom="8" left="8"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="sidebar-avatar" prefWidth="34" prefHeight="34">
                    <Label styleClass="sidebar-avatar-text" text="MG"/>
                </StackPane>
                <VBox>
                    <Label styleClass="sidebar-user-name" text="Maria G."/>
                    <Label styleClass="sidebar-user-role" text="Manager"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="btn-logout" onAction="#onLogout">
                    <graphic>
                        <SVGPath content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" styleClass="nav-svg"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>

    <VBox styleClass="main-content" HBox.hgrow="ALWAYS">
        <HBox styleClass="topbar" prefHeight="64" alignment="CENTER_LEFT">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <VBox spacing="2">
                <Label text="MANAGEMENT" styleClass="eyebrow"/>
                <Label styleClass="topbar-title" text="Menu Items" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 24;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label styleClass="topbar-date" text=""/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" maxHeight="Infinity" styleClass="content-area">
            <VBox spacing="24" VBox.vgrow="ALWAYS">
                <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox styleClass="stat-card" prefWidth="200" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: rgba(200, 80, 10, 0.1); -fx-background-radius: 8; -fx-padding: 8;">
                                <SVGPath content="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z" fill="#c8500a" scaleX="0.8" scaleY="0.8"/>
                            </StackPane>
                            <VBox>
                                <Label styleClass="stat-label" text="TOTAL ITEMS"/>
                                <Label fx:id="lblTotal" styleClass="stat-value" text="0"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox styleClass="stat-card, available" prefWidth="200" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: rgba(126, 196, 112, 0.1); -fx-background-radius: 8; -fx-padding: 8;">
                                <SVGPath content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="#7ec470" scaleX="0.8" scaleY="0.8"/>
                            </StackPane>
                            <VBox>
                                <Label styleClass="stat-label" text="AVAILABLE"/>
                                <Label fx:id="lblAvailable" styleClass="stat-value" text="0" style="-fx-text-fill: #7ec470;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox styleClass="stat-card, low-stock" prefWidth="200" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: rgba(232, 184, 75, 0.1); -fx-background-radius: 8; -fx-padding: 8;">
                                <SVGPath content="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" fill="#e8b84b" scaleX="0.8" scaleY="0.8"/>
                            </StackPane>
                            <VBox>
                                <Label styleClass="stat-label" text="LOW STOCK"/>
                                <Label fx:id="lblLowStock" styleClass="stat-value" text="0" style="-fx-text-fill: #e8b84b;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox styleClass="stat-card, out-of-stock" prefWidth="200" spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: rgba(224, 112, 112, 0.1); -fx-background-radius: 8; -fx-padding: 8;">
                                <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="#e07070" scaleX="0.8" scaleY="0.8"/>
                            </StackPane>
                            <VBox>
                                <Label styleClass="stat-label" text="OUT OF STOCK"/>
                                <Label fx:id="lblOutOfStock" styleClass="stat-value" text="0" style="-fx-text-fill: #e07070;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnAddItem" styleClass="btn-primary" text="+ ADD ITEM" prefWidth="160" onAction="#onAddItem" style="-fx-font-weight: 900; -fx-letter-spacing: 0.05em;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <HBox styleClass="filter-console" alignment="CENTER_LEFT" prefHeight="42" spacing="8" HBox.hgrow="ALWAYS">
                        <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" styleClass="search-icon-svg"/>
                        <TextField fx:id="searchField" promptText="Search menu items..." styleClass="search-field" style="-fx-background-color: transparent; -fx-border-width: 0; -fx-padding: 0 0 0 4;" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Button fx:id="btnSearch" text="SEARCH" styleClass="btn-search" onAction="#onSearchMenuItem" prefHeight="42"/>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS" maxHeight="Infinity">
                    <!-- Main Content Table with Category Sidebar -->
                    <HBox spacing="0" VBox.vgrow="ALWAYS">
                        <!-- Category Sidebar -->
                        <VBox styleClass="category-sidebar" prefWidth="180" spacing="4">
                            <Label text="CATEGORIES" styleClass="field-label" style="-fx-padding: 0 0 8 16;"/>
                            <Button fx:id="catAll" styleClass="cat-nav-item, cat-nav-item-active" text="All Items" onAction="#onCategorySelect">
                                <graphic><SVGPath content="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z" styleClass="cat-icon-svg"/></graphic>
                            </Button>
                            <Button fx:id="catBurgers" styleClass="cat-nav-item" text="Burgers" onAction="#onCategorySelect">
                                <graphic><SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" styleClass="cat-icon-svg"/></graphic>
                            </Button>
                            <Button fx:id="catChicken" styleClass="cat-nav-item" text="Chicken" onAction="#onCategorySelect">
                                <graphic><SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" styleClass="cat-icon-svg"/></graphic>
                            </Button>
                            <Button fx:id="catSides" styleClass="cat-nav-item" text="Sides" onAction="#onCategorySelect">
                                <graphic><SVGPath content="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z" styleClass="cat-icon-svg"/></graphic>
                            </Button>
                            <Button fx:id="catDrinks" styleClass="cat-nav-item" text="Drinks" onAction="#onCategorySelect">
                                <graphic><SVGPath content="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.1-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-3.45.3-5 1V7c1.55-.7 3.3-1 5-1 1.2 0 2.4.15 3.5.5v11z" styleClass="cat-icon-svg"/></graphic>
                            </Button>
                        </VBox>

                        <VBox spacing="0" styleClass="table-wrap" HBox.hgrow="ALWAYS">
                            <TableView fx:id="menuItemsTable" styleClass="menu-items-table" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn text="" fx:id="colThumbnail" prefWidth="64" minWidth="64" styleClass="cell-thumbnail"/>
                                    <TableColumn text="NAME" fx:id="colName" prefWidth="1" minWidth="240" styleClass="cell-name"/>
                                    <TableColumn text="CATEGORY" fx:id="colCategory" prefWidth="1" minWidth="140" styleClass="cell-cat"/>
                                    <TableColumn text="PRICE" fx:id="colPrice" prefWidth="1" minWidth="100" styleClass="cell-price"/>
                                    <TableColumn text="AVAILABILITY" fx:id="colAvailability" prefWidth="1" minWidth="140"/>
                                    <TableColumn text="" fx:id="colActions" prefWidth="1" minWidth="80"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>

                    <!-- Slide-out Detail Panel (Hidden by default via managed/translateX) -->
                    <HBox alignment="TOP_RIGHT" pickOnBounds="false">
                        <VBox fx:id="detailPanel" styleClass="detail-drawer" prefWidth="400" managed="false" visible="false">
                            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Button styleClass="btn-back" onAction="#onCloseDetails">
                                    <graphic><SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#8a7055"/></graphic>
                                </Button>
                                <Label text="ITEM DETAILS" styleClass="eyebrow"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button styleClass="btn-drawer-edit" text="EDIT"/>
                            </HBox>
                            
                            <VBox spacing="24" alignment="TOP_CENTER" style="-fx-padding: 32 0 0 0;">
                                <StackPane styleClass="drawer-image-wrap" prefWidth="200" prefHeight="200">
                                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z" scaleX="3" scaleY="3" fill="#332615"/>
                                </StackPane>
                                
                                <VBox spacing="8" alignment="CENTER">
                                    <Label fx:id="detailName" text="Halimaw Burger" styleClass="drawer-title"/>
                                    <Label fx:id="detailCategory" text="Burgers" styleClass="badge badge-amber"/>
                                </VBox>
                                
                                <VBox spacing="16" alignment="TOP_LEFT" styleClass="drawer-info-box" fillWidth="true">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="BASE PRICE" styleClass="field-label"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="detailPrice" text="₱150.00" styleClass="drawer-price"/>
                                    </HBox>
                                    <VBox spacing="8">
                                        <Label text="INGREDIENTS" styleClass="field-label"/>
                                        <VBox fx:id="detailIngredientsList" spacing="4"/>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </StackPane>
            </VBox>
        </StackPane>
    </VBox>

</HBox>