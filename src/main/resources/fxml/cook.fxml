<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.halimawburgersystem.CookController"
      stylesheets="@../css/common.css, @../css/login.css, @../css/dashboard.css, @../css/inventory.css, @../css/cook.css">

    <VBox styleClass="sidebar" prefWidth="240" spacing="4">
        <padding><Insets top="16" right="8" bottom="16" left="8"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-logo-section">
            <StackPane styleClass="sidebar-logo-icon" prefWidth="32" prefHeight="32">
                <SVGPath content="M6 5C6 3.89543 6.89543 3 8 3C9.10457 3 10 3.89543 10 5C10 6.10457 9.10457 7 8 7C6.89543 7 6 6.10457 6 5ZM5.49998 8L10.5 8C11.3284 8 12 8.67157 12 9.5C12 10.6161 11.541 11.5103 10.7879 12.1148C10.0466 12.7098 9.05308 13 8 13C6.94692 13 5.95342 12.7098 5.21215 12.1148C4.45897 11.5103 4 10.6161 4 9.5C4 8.67161 4.67156 8 5.49998 8ZM8 0C3.58172 0 0 3.58172 0 8C0 12.4183 3.58172 16 8 16C12.4183 16 16 12.4183 16 8C16 3.58172 12.4183 0 8 0ZM1 8C1 4.13401 4.13401 1 8 1C11.866 1 15 4.13401 15 8C15 11.866 11.866 15 8 15C4.13401 15 1 11.866 1 8Z" styleClass="logo-svg"/>
            </StackPane>
            <Label styleClass="sidebar-logo-text" text="BurgerHQ"/>
        </HBox>

        <Label styleClass="sidebar-section-label" text="KITCHEN">
            <padding><Insets top="16" left="8"/></padding>
        </Label>

        <Button fx:id="btnKitchen" styleClass="nav-item, nav-item-active" text="Kitchen Queue" onAction="#onNavigate">
            <graphic>
                <SVGPath content="M18 3v2h-2V3H8v2H6V3H4v18h2v-2h2v2h8v-2h2v2h2V3h-2zM8 17H6v-2h2v2zm0-4H6v-2h2v2zm0-4H6V7h2v2zm10 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V7h2v2z" styleClass="nav-svg"/>
            </graphic>
        </Button>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-footer">
            <padding><Insets top="12" right="8" bottom="8" left="8"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="sidebar-avatar" prefWidth="34" prefHeight="34">
                    <Label fx:id="sidebarAvatarText" styleClass="sidebar-avatar-text" text="MG"/>
                </StackPane>
                <VBox>
                    <Label fx:id="sidebarUserName" styleClass="sidebar-user-name" text="Maria G."/>
                    <Label fx:id="sidebarUserRole" styleClass="sidebar-user-role" text="Cook"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="btn-logout" onAction="#onLogout">
                    <graphic>
                        <SVGPath content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" styleClass="nav-svg"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>

    <VBox styleClass="main-content" HBox.hgrow="ALWAYS">
        <HBox styleClass="topbar" prefHeight="56">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label fx:id="pageTitle" styleClass="topbar-title" text="Kitchen Queue"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userDisplayName" styleClass="topbar-user" text="MG"/>
            <Label styleClass="topbar-separator" text="·"/>
            <Label fx:id="userDisplayRole" styleClass="topbar-role" text="Cook"/>
            <Label styleClass="topbar-date" text="Sat, Apr 18 2026 · 1:32 PM"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" maxHeight="Infinity" styleClass="content-area">
            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
            
            <HBox spacing="16" alignment="TOP_CENTER" styleClass="kanban-container">
                <!-- NEW COLUMN -->
                <VBox styleClass="kanban-col, col-new" HBox.hgrow="ALWAYS" spacing="0">
                    <HBox styleClass="kanban-col-header" alignment="CENTER_LEFT">
                        <Label styleClass="kanban-col-title" text="NEW"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="countNew" styleClass="kanban-count" text="0"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-scroll" VBox.vgrow="ALWAYS">
                        <VBox fx:id="colNew" spacing="8" styleClass="kanban-card-container"/>
                    </ScrollPane>
                </VBox>

                <!-- PREPARING COLUMN -->
                <VBox styleClass="kanban-col, col-preparing" HBox.hgrow="ALWAYS" spacing="0">
                    <HBox styleClass="kanban-col-header" alignment="CENTER_LEFT">
                        <Label styleClass="kanban-col-title" text="PREPARING"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="countPreparing" styleClass="kanban-count" text="0"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-scroll" VBox.vgrow="ALWAYS">
                        <VBox fx:id="colPreparing" spacing="8" styleClass="kanban-card-container"/>
                    </ScrollPane>
                </VBox>

                <!-- READY COLUMN -->
                <VBox styleClass="kanban-col, col-ready" HBox.hgrow="ALWAYS" spacing="0">
                    <HBox styleClass="kanban-col-header" alignment="CENTER_LEFT">
                        <Label styleClass="kanban-col-title" text="READY"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="countReady" styleClass="kanban-count" text="0"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-scroll" VBox.vgrow="ALWAYS">
                        <VBox fx:id="colReady" spacing="8" styleClass="kanban-card-container"/>
                    </ScrollPane>
                </VBox>
            </HBox>
        </StackPane>
    </VBox>

</HBox>