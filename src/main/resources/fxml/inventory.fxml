<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myapp.halimawburgersystem.InventoryController"
      stylesheets="@../css/common.css, @../css/dashboard.css"
      styleClass="content-area">

    <padding><Insets top="24" right="32" bottom="0" left="32"/></padding>

    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox styleClass="stat-card" prefWidth="180">
            <Label styleClass="stat-label" text="TOTAL INGREDIENTS"/>
            <Label fx:id="lblTotal" styleClass="stat-value" text="0"/>
        </VBox>
        <VBox styleClass="stat-card" prefWidth="180">
            <Label styleClass="stat-label" text="LOW STOCK"/>
            <Label fx:id="lblLowStock" styleClass="stat-value" text="0" style="-fx-text-fill: #e8b84b;"/>
        </VBox>
        <VBox styleClass="stat-card" prefWidth="180">
            <Label styleClass="stat-label" text="OUT OF STOCK"/>
            <Label fx:id="lblOutOfStock" styleClass="stat-value" text="0" style="-fx-text-fill: #e07070;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button styleClass="btn-primary" text="RESTOCK" onAction="#onRestock"/>
        <Button styleClass="btn-primary" text="ADD INGREDIENT" onAction="#onAddIngredient"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" styleClass="table-wrap">
        <padding><Insets top="24" bottom="0"/></padding>
        <TableView fx:id="inventoryTable">
            <columns>
                <TableColumn text="INGREDIENT" fx:id="colName" prefWidth="200"/>
                <TableColumn text="REMAINING" fx:id="colQuantity" prefWidth="100"/>
                <TableColumn text="UNIT" fx:id="colUnit" prefWidth="80"/>
                <TableColumn text="STATUS" fx:id="colStatus" prefWidth="100"/>
            </columns>
        </TableView>
    </StackPane>

</VBox>